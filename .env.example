# --- Local development (default) ---------------------------------------------
# Leave DATABASE_URL unset to use the zero-config embedded database (PGlite),
# which persists to ./.pglite. This is real Postgres compiled to WASM — no
# Docker or Postgres server required.

# --- Production / hosted Postgres --------------------------------------------
# Set DATABASE_URL to a real Postgres connection string (Neon, Supabase, RDS,
# a local server, etc.) and the app will use it via postgres.js instead.
# DATABASE_URL=postgres://user:password@localhost:5432/runplan

# Secret used to sign/verify session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-only-insecure-secret-change-me

# Shared secret for the scheduled Garmin sync endpoint (POST /api/garmin/sync-all
# with an "x-cron-secret" header). Leave unset to disable scheduled syncs;
# the manual "Sync now" button in Settings works either way.
# CRON_SECRET=

# --- Email (password reset) ---------------------------------------------------
# SMTP settings for the "forgot password" email. Leave unset to disable —
# the UI still works, but reset emails are skipped (logged server-side).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="RunPlan <you@gmail.com>"

# Public base URL of the app — used in emails and for passkey (WebAuthn)
# origin/RP ID. Passkeys only work on this HTTPS origin.
# APP_URL=https://runplan.example.com

# --- Google sign-in (optional) -------------------------------------------------
# OAuth client from https://console.cloud.google.com/apis/credentials
# (Web application; authorized redirect URI = ${APP_URL}/api/auth/google/callback).
# Leave unset to hide the "Continue with Google" buttons.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Stripe billing (optional) --------------------------------------------------
# Secret key + subscription price ids; webhook secret from the endpoint config.
# Leave unset to hide billing UI (all Pro gates still apply to non-pro accounts).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_YEARLY=

# Owner notifications (new subscriber / cancellation emails). Optional.
# ADMIN_EMAIL=you@example.com
