# --- Local development (default) ---------------------------------------------
# Leave DATABASE_URL unset to use the zero-config embedded database (PGlite),
# which persists to ./.pglite. This is real Postgres compiled to WASM — no
# Docker or Postgres server required.

# --- Production / hosted Postgres --------------------------------------------
# Set DATABASE_URL to a real Postgres connection string (Neon, Supabase, RDS,
# a local server, etc.) and the app will use it via postgres.js instead.
# DATABASE_URL=postgres://user:password@localhost:5432/runplan

# Secret used to sign/verify session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-only-insecure-secret-change-me
